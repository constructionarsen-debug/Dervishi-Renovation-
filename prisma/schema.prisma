generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
}

enum OrderType {
  QA
  EBOOK
}

enum PaymentStatus {
  UNPAID
  PENDING
  PAID
  FAILED
  CANCELED
}

enum QuestionStatus {
  OPEN
  ANSWERED
  CLOSED
}

enum MessageSender {
  USER
  ADMIN
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  emailVerified DateTime?
  name         String?
  image        String?
  googleId     String?  @unique
  passwordHash String?
  role         UserRole @default(USER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // NextAuth relations (SHTO KETO)
  accounts     Account[]
  sessions     Session[]

  // existing relations
  orders       Order[]
  questions    Question[]
  ebookAccess  EbookAccess[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model EbookAccess {
  id        String   @id @default(cuid())
  userId    String
  ebookId   String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  ebook Ebook @relation(fields: [ebookId], references: [id], onDelete: Cascade)

  @@unique([userId, ebookId])
}

model Project {
  id          String   @id @default(cuid())
  title       String
  location    String?
  description String?
  coverImage  String?
  images      String[] @default([])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Testimonial {
  id        String   @id @default(cuid())
  name      String
  role      String?
  quote     String
  rating    Int      @default(5)
  createdAt DateTime @default(now())
}

model PriceSetting {
  id           String   @id @default(cuid())
  key          String   @unique
  title        String
  description  String?
  priceLek     Int
  updatedAt    DateTime @updatedAt
  createdAt    DateTime @default(now())
}

model Question {
  id         String   @id @default(cuid())
  name       String
  email      String
  message    String
  answer     String?
  answeredAt DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  status     QuestionStatus @default(OPEN)
  phone      String?

  userId String?
  user   User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  order  Order?

  messages QuestionMessage[]
}

model QuestionMessage {
  id         String   @id @default(cuid())
  questionId String
  sender     MessageSender
  senderUserId String?
  content    String
  createdAt  DateTime @default(now())

  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
}

model Ebook {
  id            String   @id @default(cuid())
  slug          String   @unique
  title         String
  shortDesc     String
  longDesc      String?
  priceLek      Int
  coverImage    String?
  previewMedia  String[]
  contentMedia  String[] @default([])
  contentUrl    String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  orders        Order[]
  access        EbookAccess[]
}

model Order {
  id            String        @id @default(cuid())
  type          OrderType
  paymentStatus PaymentStatus @default(UNPAID)
  amountLek     Int
  customerName  String
  customerEmail String
  accessToken   String        @unique
  payseraRef    String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  userId String?
  user   User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  questionId String?   @unique
  question   Question? @relation(fields: [questionId], references: [id])

  ebookId String?
  ebook   Ebook? @relation(fields: [ebookId], references: [id])
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  message   String
  createdAt DateTime @default(now())
  handled   Boolean  @default(false)
}
